APP_NAME=ibkr-dashboard-backend

# Storage backend:
# - http (default, persistent local Elasticsearch)
# - in_memory (optional, ephemeral dev/test)
ES_BACKEND=http
ES_BASE_URL=http://localhost:9200
ES_HOST=

ES_TIMEOUT_SECONDS=5.0
ES_USERNAME=
ES_PASSWORD=
ES_API_KEY=
# Example: {"X-My-Header":"value"}
ES_EXTRA_HEADERS_JSON={}

# Runtime application settings (managed by /api/settings):
# - finnhub_api_key
# - flex_token
# - flex_query_id
# - base_currency
# - timezone
# - display_realtime_prices
